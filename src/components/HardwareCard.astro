---
interface Props {
  title: string;
  description: string;
  price: string;
  affiliateLink: string;
  imageUrl: string;
}

const { title, description, price, affiliateLink, imageUrl } = Astro.props;
---

<article class="flex flex-col md:flex-row gap-6 border-2 border-foreground bg-background p-4 shadow-[6px_6px_0_0_#ffffff] hover:shadow-[2px_2px_0_0_#39ff14] hover:border-accent hover:translate-x-1 hover:translate-y-1 transition-all duration-75 group">
  <div class="w-full md:w-1/3 aspect-square border-2 border-foreground overflow-hidden">
    <img 
      src={imageUrl} 
      alt={`Image of ${title}`} 
      class="w-full h-full object-cover object-center grayscale group-hover:grayscale-0 transition-all duration-75"
      loading="lazy"
    />
  </div>
  
  <div class="flex flex-col justify-between w-full md:w-2/3">
    <div>
      <h3 class="text-2xl font-bold uppercase tracking-widest text-foreground group-hover:text-accent m-0 pb-2 border-b-2 border-foreground mb-4">
        {title}
      </h3>
      <p class="text-lg leading-relaxed text-gray-300 mb-6">
        {description}
      </p>
    </div>
    
    <div class="flex items-center justify-between border-t-2 border-foreground pt-4 mt-auto">
      <span class="text-xl font-bold font-mono text-accent-alt">
        {price}
      </span>
      <a 
        href={affiliateLink} 
        target="_blank" 
        rel="noopener noreferrer" 
        class="inline-block border-2 border-foreground bg-foreground text-background font-bold uppercase tracking-wider px-6 py-3 hover:bg-accent hover:border-accent hover:text-background shadow-[4px_4px_0_0_#b026ff] hover:shadow-none hover:translate-x-1 hover:translate-y-1 transition-all duration-75"
      >
        Acquire Hardware _>
      </a>
    </div>
  </div>
</article>
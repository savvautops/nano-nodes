---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header class="border-b-4 border-foreground bg-background mb-8">
  <nav class="max-w-4xl mx-auto px-4 py-6 flex flex-col md:flex-row justify-between items-center gap-4">
    <h2 class="m-0 text-2xl font-bold uppercase tracking-widest">
      <a href="/" class="text-foreground hover:text-accent transition-colors duration-75 no-underline">
        [{SITE_TITLE}]
      </a>
    </h2>
    <div class="flex gap-6 items-center uppercase text-sm font-bold tracking-wider">
      <HeaderLink href="/" class="text-muted hover:text-accent hover:border-b-2 hover:border-accent">Home</HeaderLink>
      <HeaderLink href="/tutorials" class="text-muted hover:text-accent hover:border-b-2 hover:border-accent">Tutorials</HeaderLink>
      <HeaderLink href="/gear" class="text-muted hover:text-accent-alt hover:border-b-2 hover:border-accent-alt">Gear</HeaderLink>
      <button id="theme-toggle" class="ml-4 border-2 border-foreground bg-background text-foreground px-3 py-1 font-bold text-xs uppercase tracking-widest shadow-[2px_2px_0_0_var(--color-foreground)] hover:shadow-none hover:translate-x-0.5 hover:translate-y-0.5 transition-all">
        [Invert]
      </button>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('theme-toggle');
  if (toggle) {
    toggle.addEventListener('click', () => {
      const currentTheme = document.documentElement.getAttribute('data-theme');
      const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', newTheme);
      localStorage.setItem('theme', newTheme);
    });
  }
</script>
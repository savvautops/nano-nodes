---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header class="border-b-4 border-foreground bg-background mb-8">
  <nav class="max-w-4xl mx-auto px-4 py-6 flex flex-col md:flex-row justify-between items-center gap-4">
    <h2 class="m-0 text-2xl font-bold uppercase tracking-widest">
      <a href="/" class="text-foreground hover:text-accent transition-colors duration-75 no-underline">
        [{SITE_TITLE}]
      </a>
    </h2>
    <div class="flex gap-6 items-center uppercase text-sm font-bold tracking-wider">
      <HeaderLink href="/" class="text-gray-400 hover:text-accent hover:border-b-2 hover:border-accent">Home</HeaderLink>
      <HeaderLink href="/tutorials" class="text-gray-400 hover:text-accent hover:border-b-2 hover:border-accent">Tutorials</HeaderLink>
      <HeaderLink href="/gear" class="text-gray-400 hover:text-accent-alt hover:border-b-2 hover:border-accent-alt">Gear</HeaderLink>
      <HeaderLink href="/about" class="text-gray-400 hover:text-foreground hover:border-b-2 hover:border-foreground">About</HeaderLink>
    </div>
  </nav>
</header>
